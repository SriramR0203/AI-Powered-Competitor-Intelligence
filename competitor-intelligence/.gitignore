# ── Maven build output ────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── IDE ───────────────────────────────────────────────
.idea/
.idea/**
*.iml
*.iws
*.ipr
