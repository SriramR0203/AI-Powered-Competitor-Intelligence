# ── Spring Profile ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=competitor_intel
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-strong-random-secret-at-least-64-characters-long
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── AI Providers (optional — set one or both) ─────────────────────────────────
AI_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Mail (optional) ───────────────────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
