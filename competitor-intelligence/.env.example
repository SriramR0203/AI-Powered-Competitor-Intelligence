# ═══════════════════════════════════════════════════════════════════════════════
# AI-Powered Competitor Intelligence Platform — Backend Environment Variables
#
# LOCAL DEVELOPMENT (H2 — no database setup needed):
#   Just run:  mvn spring-boot:run
#   The dev profile activates H2 automatically; no .env file is required.
#
# LOCAL DEVELOPMENT (PostgreSQL):
#   cp .env.example .env
#   Fill in DB_* and JWT_SECRET, then:
#   mvn spring-boot:run -Dspring-boot.run.profiles=prod
#
# RENDER PRODUCTION:
#   Set these directly in Render Dashboard → Service → Environment.
#   SPRING_DATASOURCE_URL must be set to the Neon JDBC connection string.
#   See the Database section below for the exact format.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Spring Profile ────────────────────────────────────────────────────────────
# dev  = H2 in-memory (default, no setup needed)
# prod = PostgreSQL
SPRING_PROFILES_ACTIVE=prod

# ── Database ──────────────────────────────────────────────────────────────────
# RENDER PRODUCTION (Neon PostgreSQL):
#   Copy the JDBC connection string from your Neon dashboard:
#     Project → Connection Details → Connection string → JDBC
#   It looks like:
#     jdbc:postgresql://<host>.neon.tech/<db>?user=<user>&password=<pass>&sslmode=require
#   Paste the entire string as the value of SPRING_DATASOURCE_URL in the
#   Render Dashboard → Service → Environment.  Do not commit the real value.
#
# LOCAL DEVELOPMENT with PostgreSQL (optional — H2 is used by default):
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/competitor_intel
SPRING_DATASOURCE_USERNAME=competitor_user
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate a secure secret:
#   openssl rand -base64 64
JWT_SECRET=replace-with-a-strong-random-secret-minimum-64-characters-long
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the React frontend.
# Local dev — Vite dev server:
ALLOWED_ORIGINS=http://localhost:5173
# Production — set to your Vercel URL after deploying:
# ALLOWED_ORIGINS=https://competitor-intel.vercel.app

# ── AI Providers (optional) ───────────────────────────────────────────────────
# Leave AI_PROVIDER=mock to use the built-in mock (no API key needed).
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Mail (optional — for alert email notifications) ───────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
# Render sets PORT automatically. Do not override in production.
SERVER_PORT=8080
