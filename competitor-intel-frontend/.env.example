# ═══════════════════════════════════════════════════════════════════════════════
# AI-Powered Competitor Intelligence Platform — Frontend Environment Variables
#
# LOCAL DEVELOPMENT:
#   cp .env.example .env
#   The defaults below work out of the box with the Spring Boot dev server.
#
# VERCEL PRODUCTION:
#   Do NOT commit .env.  Instead set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend base URL — NO trailing slash ──────────────────────────────────────
# Local development (H2 backend):
VITE_API_BASE_URL=http://localhost:8080

# Production (Render) — replace with your actual Render service URL:
# VITE_API_BASE_URL=https://competitor-intel-api.onrender.com

# ── Request timeout in milliseconds ──────────────────────────────────────────
VITE_API_TIMEOUT=15000
